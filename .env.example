# =============================================================================
# INDICE RAPIDO
# - Firebase, IA, SEO, Push: mas abajo
# - SUPER ADMIN (APP_ADMIN_EMAIL / PASSWORD + curl): al FINAL de este archivo
# =============================================================================
#
# App Identity — configurables para white-label
# Fallback si no se define: "sionflow"
NEXT_PUBLIC_APP_NAME="sionflow"
# Logo en /public (ej: "/logo.png"). Si no se define, usa /logo.png por defecto.
NEXT_PUBLIC_APP_LOGO=""
# Icono para PWA y pestaña del navegador (URL completa, ej: https://.../icon-512.png)
# Si no se define, usa /icono-app.png como fallback.
NEXT_PUBLIC_APP_ICON=""

# Firebase configuration - replace with your project's credentials
NEXT_PUBLIC_FIREBASE_API_KEY="your-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-app-id"
FIREBASE_SERVICE_ACCOUNT_KEY={"key":"your-service-account-key"}

# ── IA ──────────────────────────────────────────────────────────────────────
#
# DEEPSEEK = IA de TODO el sistema en TEXTO (casi todas las funciones de IA):
#   - Resumen inteligente del dashboard
#   - Sugerencias de actividades y de servicio
#   - Chat Iglesia (conversación / respuestas)
#   - Reescritura opcional de textos
#   - Cualquier flujo de texto vía @/lib/deepseek
# DeepSeek NO analiza fotos (su API de chat no acepta imágenes).
# Clave: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key
# Optional: modelo global de texto (default: deepseek-chat)
DEEPSEEK_MODEL=deepseek-v4-flash
# Optional: modelo del Chat Iglesia (default: deepseek-v4-flash)
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
# Optional: límite de tokens de salida del Chat Iglesia (default: 1600)
DEEPSEEK_MAX_TOKENS=1600
# Optional: timeout de cada request a DeepSeek en ms (default: 30000)
# No uses 8000 (legacy): corta church-chat y devuelve 504. Mínimo efectivo en código: 25000.
DEEPSEEK_TIMEOUT_MS=30000

# GEMINI = IA SOLO para IMÁGENES (visión):
#   - Descripción automática al subir fotos en Obra misional (tab Imágenes)
#   - Análisis de imagen adjunta en el Chat Iglesia (luego DeepSeek responde en texto)
# No sustituye a DeepSeek: Gemini no se usa para chat, resúmenes ni sugerencias.
# Clave gratis: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Alias opcional (mismo valor que GEMINI_API_KEY):
# GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
# Optional: modelo de visión (default: gemini-2.5-flash-lite; 2.0-flash ya no está disponible)
GEMINI_VISION_MODEL=gemini-2.5-flash-lite

# SEO & Site Identity
# URL canónica del sitio (sin trailing slash). Usada para sitemap, canonical, OG.
NEXT_PUBLIC_SITE_URL=""
# Descripción para metadata, OG, Twitter Cards y JSON-LD (Schema.org)
NEXT_PUBLIC_APP_DESCRIPTION="Sistema de gestión para presidencias de Quorum de Elderes y Sociedad de Socorro. Administración de miembros, conversos, ministerio, obra misional, informes y consejo con IA integrada."

# PWA Push Notifications / Web Push Firebase
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# External API (read-only, Firebase Auth secured)
# No extra env vars needed. Uses FIREBASE_SERVICE_ACCOUNT_KEY above.
# Endpoints:
#   GET /api/external/ministering
#   GET /api/external/activities?year=YYYY
#   GET /api/external/services?year=YYYY
# Auth: Authorization: Bearer <Firebase-ID-token>
# Scope: data is auto-filtered by the authenticated user's barrio+organización in c_users

# ═══════════════════════════════════════════════════════════════════════════
# SUPER ADMIN — panel /app-admin (léelo si vas a montar el proyecto)
# ═══════════════════════════════════════════════════════════════════════════
#
# Para saber quién es el super admin, mira estas variables:
#
#   APP_ADMIN_EMAIL     = correo del SUPER ADMIN (usuario de login)
#   APP_ADMIN_PASSWORD  = contraseña del SUPER ADMIN
#
# Esas dos son las credenciales del super admin.
# Cuando ejecutes el "curl" de más abajo, se crearán EN FIREBASE
# (Authentication + c_users) con exactamente esos valores.
# No se crean solas al copiar el .env: hace falta el curl (o el script).
#
# Copia este archivo a .env,
# cambia email/password por los tuyos, y sigue los pasos.
#
# --- Credenciales del super admin (cámbialas) ---
APP_ADMIN_EMAIL=admin@sionflow.app
APP_ADMIN_PASSWORD=CambiaEstaClaveSegura123!
#
# --- Código solo para el comando curl (NO es la contraseña de login) ---
# Debe coincidir con el "secret" del curl. Mínimo 8 caracteres. No lo publiques.
APP_ADMIN_BOOTSTRAP_SECRET=cambia-este-secreto-bootstrap
# Solo en recuperación de emergencia: permite que re-bootstrap cambie el password.
# Déjalo vacío/false en producción normal (si el secret se filtra, no resetean la clave).
# APP_ADMIN_BOOTSTRAP_ALLOW_RESET=false
#
# --- Cómo crear el super admin en Firebase (una vez) ---
#
#   1. Edita APP_ADMIN_EMAIL y APP_ADMIN_PASSWORD arriba.
#   2. Guarda como .env.local (o configura .env.production).
#   3. Terminal 1:  pnpm dev
#   4. Terminal 2 — COPIA Y PEGA este curl (ajusta el secret si lo cambiaste):
#
#        curl -X POST http://localhost:9001/api/app-admin/bootstrap \
#          -H "Content-Type: application/json" \
#          -d '{"secret":"cambia-este-secreto-bootstrap"}'
#
#      Qué hace ese curl:
#        - Lee APP_ADMIN_EMAIL y APP_ADMIN_PASSWORD de tu .env
#        - Crea/actualiza ese usuario en Firebase Auth
#        - Escribe c_users con isAppAdmin: true
#        - Responde JSON tipo: {"ok":true,"created":true,"email":"..."}
#
#   5. Navegador: http://localhost:9001/app-admin/login
#      Correo     = APP_ADMIN_EMAIL
#      Contraseña = APP_ADMIN_PASSWORD
#
#   Producción (alternativa al curl): node scripts/bootstrap-app-admin-prod.mjs
#
# curl = comando de TERMINAL (no abras esa URL en el navegador).
# Después puedes cambiar correo/clave del super admin con “Mi cuenta” en el panel.
#
# Rutas:
#   /app-admin/login  y  /app-admin/panel  → super admin
#   /admin                                 → admin de barrio (otra cosa)


