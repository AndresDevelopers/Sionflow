rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/c_users/$(request.auth.uid)).data;
    }

    function currentUserRole() {
      return currentUserDoc().role;
    }

    function currentUserPermission() {
      return currentUserDoc().permission;
    }

    function currentUserBarrioOrg() {
      // Prefer explicit barrioOrg field (canonical multi-tenant key)
      let d = currentUserDoc();
      return d.barrioOrg;
    }

    // Accept canonical 'all' and legacy Spanish aliases stored in older docs
    function canWrite() {
      let perm = currentUserPermission();
      return signedIn() && (perm == 'all' || perm == 'todo' || perm == 'todos');
    }

    function isOwnUserId(userId) {
      return signedIn() && userId != null && userId == request.auth.uid;
    }

    function isSecretary() {
      return signedIn() && (currentUserRole() == 'secretary' || currentUserRole() == 'president' || currentUserRole() == 'admin');
    }

    function isSameBarrio(docBarrioOrg) {
      return signedIn()
        && docBarrioOrg != null
        && currentUserBarrioOrg() != null
        && docBarrioOrg == currentUserBarrioOrg();
    }

    function isSecretaryInSameBarrio(docBarrioOrg) {
      return isSecretary() && isSameBarrio(docBarrioOrg);
    }

    // create/update: validar barrio del documento resultante
    function canCreateInBarrio() {
      return canWrite() && isSameBarrio(request.resource.data.barrioOrg);
    }

    // update: el doc existente debe ser del mismo barrio Y barrioOrg es inmutable.
    // Fail closed: no reasignar docs de otro tenant (el OR antiguo permitía robar
    // un docId ajeno y poner request.resource.barrioOrg = el del atacante).
    // Re-sellado de legacy sin barrioOrg: solo Admin SDK (/api/admin/migrate-barrio-org).
    function barrioOrgUnchanged() {
      return request.resource.data.barrioOrg == resource.data.barrioOrg;
    }

    function canUpdateInBarrio() {
      return canWrite()
        && isSameBarrio(resource.data.barrioOrg)
        && barrioOrgUnchanged();
    }

    // delete no tiene request.resource; validar barrio del documento existente
    function canDeleteInBarrio() {
      return (canWrite() || isSecretary()) && isSameBarrio(resource.data.barrioOrg);
    }

    function isAnnotationOwner() {
      return signedIn()
        && resource.data.userId != null
        && resource.data.userId == request.auth.uid;
    }

    function isCreatingOwnAnnotation() {
      return signedIn()
        && request.resource.data.userId != null
        && request.resource.data.userId == request.auth.uid;
    }

    // ── Data collections — scoped by barrioOrg ──

    match /c_miembros/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if canCreateInBarrio();
      allow update: if canUpdateInBarrio();
      allow delete: if canDeleteInBarrio();
    }

    match /c_anotaciones/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if isCreatingOwnAnnotation()
        && canWrite()
        && isSameBarrio(request.resource.data.barrioOrg);
      allow update: if (isSecretary() || isAnnotationOwner())
        && canWrite()
        && request.resource.data.userId == resource.data.userId
        && isSameBarrio(resource.data.barrioOrg)
        && barrioOrgUnchanged();
      allow delete: if (isSecretary() || isAnnotationOwner())
        && canWrite()
        && isSameBarrio(resource.data.barrioOrg);
    }

    match /c_conversos/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if canCreateInBarrio();
      allow update: if canUpdateInBarrio();
      allow delete: if canDeleteInBarrio();
    }

    match /c_conversos_info/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if canCreateInBarrio();
      allow update: if canUpdateInBarrio();
      allow delete: if canDeleteInBarrio();
    }

    match /c_futuros_miembros/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if canCreateInBarrio();
      allow update: if canUpdateInBarrio();
      allow delete: if canDeleteInBarrio();
    }

    match /c_ministracion/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if canCreateInBarrio();
      allow update: if canUpdateInBarrio();
      allow delete: if canDeleteInBarrio();
    }

    match /c_actividades/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if canCreateInBarrio();
      allow update: if canUpdateInBarrio();
      allow delete: if canDeleteInBarrio();
    }

    match /c_servicios/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if canCreateInBarrio();
      allow update: if canUpdateInBarrio();
      allow delete: if canDeleteInBarrio();
    }

    match /c_cumpleanos/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if canCreateInBarrio();
      allow update: if canUpdateInBarrio();
      allow delete: if canDeleteInBarrio();
    }

    match /c_bautismos/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if canCreateInBarrio();
      allow update: if canUpdateInBarrio();
      allow delete: if canDeleteInBarrio();
    }

    match /c_fs_capacitaciones/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if canCreateInBarrio();
      allow update: if canUpdateInBarrio();
      allow delete: if canDeleteInBarrio();
    }

    match /c_fs_pendientes/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if canCreateInBarrio();
      allow update: if canUpdateInBarrio();
      allow delete: if canDeleteInBarrio();
    }

    match /c_fs_anotaciones/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if isCreatingOwnAnnotation()
        && canWrite()
        && isSameBarrio(request.resource.data.barrioOrg);
      allow update: if (isSecretary() || isAnnotationOwner())
        && canWrite()
        && request.resource.data.userId == resource.data.userId
        && isSameBarrio(resource.data.barrioOrg)
        && barrioOrgUnchanged();
      allow delete: if (isSecretary() || isAnnotationOwner())
        && canWrite()
        && isSameBarrio(resource.data.barrioOrg);
    }

    match /c_obra_misional_asignaciones/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if canCreateInBarrio();
      allow update: if canUpdateInBarrio();
      allow delete: if canDeleteInBarrio();
    }

    match /c_obra_misional_investigadores/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if canCreateInBarrio();
      allow update: if canUpdateInBarrio();
      allow delete: if canDeleteInBarrio();
    }

    match /c_obra_misional_amigos_conversos/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if canCreateInBarrio();
      allow update: if canUpdateInBarrio();
      allow delete: if canDeleteInBarrio();
    }

    match /c_obra_misional_imagenes/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if canCreateInBarrio();
      allow update: if canUpdateInBarrio();
      allow delete: if canDeleteInBarrio();
    }

    match /c_ministracion_distritos/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if canCreateInBarrio();
      allow update: if canUpdateInBarrio();
      allow delete: if canDeleteInBarrio();
    }

    match /c_ministracion_historial/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if canCreateInBarrio();
      allow update: if canUpdateInBarrio();
      allow delete: if canDeleteInBarrio();
    }

    match /c_ministracion_entrevistas/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if canCreateInBarrio();
      allow update: if canUpdateInBarrio();
      allow delete: if canDeleteInBarrio();
    }

    match /c_observaciones_salud/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if canCreateInBarrio();
      allow update: if canUpdateInBarrio();
      allow delete: if canDeleteInBarrio();
    }

    // Sync signals written by Cloud Functions (Admin SDK). Clients read-only for own barrio.
    match /c_sync_signals/{document} {
      allow read: if signedIn() && resource.data.barrioOrg == currentUserBarrioOrg();
      allow write: if false;
    }

    match /c_notifications/{document} {
      // Strict owner isolation on read: peers must not read others' notification PII
      allow read: if isOwnUserId(resource.data.userId);
      // Leadership may fan-out in-app notifs to same barrio; self-create also allowed.
      // barrioOrg is required so docs are never unscoped (fail closed for multi-tenant).
      allow create: if request.resource.data.userId != null
        && request.resource.data.barrioOrg != null
        && isSameBarrio(request.resource.data.barrioOrg)
        && (
          isOwnUserId(request.resource.data.userId)
          || canWrite()
        );
      // Owner may mark read and soft-dismiss (trash in bell). Soft-dismiss keeps
      // the doc so scheduled CF deterministic creates do not reappear the same day.
      allow update: if isOwnUserId(resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['isRead', 'isDismissed']);
      allow delete: if isOwnUserId(resource.data.userId);
    }

    // ── User-scoped collections ──

    // Personal push tokens — independent of Lectura/Todo data permissions
    match /c_push_subscriptions/{document} {
      allow read: if isOwnUserId(resource.data.userId);
      allow create, update: if isOwnUserId(request.resource.data.userId);
      allow delete: if isOwnUserId(resource.data.userId);
    }

    // Per-device permissions (GPS, microphone) — same pattern as push subscriptions
    // Uses resource.data.get() so reads of non-existent docs don't fail the rule
    match /c_device_permissions/{document} {
      allow read: if signedIn() && resource.data.get('userId', request.auth.uid) == request.auth.uid;
      allow create, update: if signedIn() && request.auth.uid == request.resource.data.userId;
      allow delete: if signedIn() && resource.data.get('userId', '') == request.auth.uid;
    }

    // Audit — leadership, same barrio only
    match /c_admin_audit/{document} {
      allow read: if isSecretaryInSameBarrio(resource.data.barrioOrg);
      allow create: if isSecretaryInSameBarrio(request.resource.data.barrioOrg)
        && request.resource.data.actorUid == request.auth.uid;
      allow update, delete: if false;
    }

    // Users — own profile always; peers only same barrioOrg (never global list)
    //
    // Super-admin (panel /app-admin):
    //   - Se crea solo con Admin SDK (bootstrap / API server).
    //   - El cliente NUNCA puede poner isAppAdmin ni el tenant __system__|__app_admin__.
    //   - El doc del super-admin no se borra ni se "promueve" desde la app de barrio.
    //   - Lectura global de usuarios del panel usa Admin SDK (estas rules no la permiten).
    function isSystemAppAdminBarrioOrg(value) {
      return value == '__system__|__app_admin__';
    }

    function resourceIsAppAdminUser() {
      return resource.data.get('isAppAdmin', false) == true
        || isSystemAppAdminBarrioOrg(resource.data.get('barrioOrg', ''));
    }

    function requestClaimsAppAdmin() {
      return request.resource.data.get('isAppAdmin', false) == true
        || isSystemAppAdminBarrioOrg(request.resource.data.get('barrioOrg', ''))
        || request.resource.data.get('barrio', '') == '__system__'
        || request.resource.data.get('organizacion', '') == '__app_admin__';
    }

    // Create: no auto-promoción a super-admin
    function clientCannotSetAppAdminOnCreate() {
      return requestClaimsAppAdmin() == false;
    }

    // Update: no tocar flag/tenant de super-admin ni elevar el doc resultante
    function clientCannotChangeOrClaimAppAdmin() {
      return !request.resource.data.diff(resource.data).changedKeys()
          .hasAny(['isAppAdmin'])
        && requestClaimsAppAdmin() == false
        // Tampoco se puede "desproteger" mutando el perfil del super-admin desde cliente
        && resourceIsAppAdminUser() == false;
    }

    match /c_users/{document} {
      allow read: if signedIn()
        && (
          document == request.auth.uid
          || (
            isSameBarrio(resource.data.barrioOrg)
            // Peers no leen el doc del super-admin aunque compartieran algo raro
            && resourceIsAppAdminUser() == false
          )
        );
      allow create: if signedIn()
        && document == request.auth.uid
        && clientCannotSetAppAdminOnCreate();
      allow update: if signedIn()
        && clientCannotChangeOrClaimAppAdmin()
        && (
          (
            // Leadership can manage roles only within their own barrio
            isSecretaryInSameBarrio(resource.data.barrioOrg)
            && isSameBarrio(request.resource.data.barrioOrg)
          )
          || (
            document == request.auth.uid
            && !request.resource.data.diff(resource.data).changedKeys().hasAny([
              'role',
              'permission',
              'barrioOrg',
              'barrio',
              'organizacion'
            ])
          )
        );
      // Nunca borrar al super-admin desde el cliente
      allow delete: if isSecretaryInSameBarrio(resource.data.barrioOrg)
        && resourceIsAppAdminUser() == false;
    }

    // ── Reference data — public read (names only for registration) ──

    match /c_donate_config/{document} {
      // Global app configuration; readable by any signed-in user.
      allow read: if signedIn();
      // Only leadership can change the donation link/QR.
      allow create, update, delete: if isSecretary();
    }

    match /c_barrios/{document} {
      allow read: if true;
      // Only leadership can mutate reference lists
      allow write: if isSecretary();
    }

    match /c_organizaciones/{document} {
      allow read: if true;
      allow write: if isSecretary();
    }

    // ── Default: deny everything not explicitly matched ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
