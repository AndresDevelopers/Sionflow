rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserRole() {
      return get(/databases/$(database)/documents/c_users/$(request.auth.uid)).data.role;
    }

    function currentUserPermission() {
      return get(/databases/$(database)/documents/c_users/$(request.auth.uid)).data.permission;
    }

    function currentUserBarrioOrg() {
      return get(/databases/$(database)/documents/c_users/$(request.auth.uid)).data.barrioOrg;
    }

    function canWrite() {
      return signedIn() && currentUserPermission() == 'all';
    }

    function isSecretary() {
      return signedIn() && (currentUserRole() == 'secretary' || currentUserRole() == 'president' || currentUserRole() == 'admin');
    }

    function isSameBarrio(docBarrioOrg) {
      return signedIn() && docBarrioOrg == currentUserBarrioOrg();
    }

    function isAnnotationOwner() {
      return signedIn()
        && resource.data.userId != null
        && resource.data.userId == request.auth.uid;
    }

    function isCreatingOwnAnnotation() {
      return signedIn()
        && request.resource.data.userId != null
        && request.resource.data.userId == request.auth.uid;
    }

    // ── Data collections — scoped by barrioOrg ──

    match /c_miembros/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow write: if canWrite() && isSameBarrio(request.resource.data.barrioOrg);
    }

    match /c_anotaciones/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if isCreatingOwnAnnotation()
        && canWrite()
        && isSameBarrio(request.resource.data.barrioOrg);
      allow update: if (isSecretary() || isAnnotationOwner())
        && canWrite()
        && request.resource.data.userId == resource.data.userId
        && isSameBarrio(resource.data.barrioOrg);
      allow delete: if (isSecretary() || isAnnotationOwner())
        && canWrite()
        && isSameBarrio(resource.data.barrioOrg);
    }

    match /c_conversos/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow write: if canWrite() && isSameBarrio(request.resource.data.barrioOrg);
    }

    match /c_conversos_info/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow write: if canWrite() && isSameBarrio(request.resource.data.barrioOrg);
    }

    match /c_futuros_miembros/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow write: if canWrite() && isSameBarrio(request.resource.data.barrioOrg);
    }

    match /c_ministracion/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      // create: validar barrio del documento nuevo
      allow create: if canWrite() && isSameBarrio(request.resource.data.barrioOrg);
      // update: validar barrio del documento existente (funciona con updates parciales)
      allow update: if canWrite()
        && (isSameBarrio(resource.data.barrioOrg) || isSameBarrio(request.resource.data.barrioOrg));
      allow delete: if canWrite() && isSameBarrio(resource.data.barrioOrg);
    }

    match /c_actividades/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow write: if canWrite() && isSameBarrio(request.resource.data.barrioOrg);
    }

    match /c_servicios/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow write: if canWrite() && isSameBarrio(request.resource.data.barrioOrg);
    }

    match /c_cumpleanos/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow write: if canWrite() && isSameBarrio(request.resource.data.barrioOrg);
    }

    match /c_bautismos/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow write: if canWrite() && isSameBarrio(request.resource.data.barrioOrg);
    }

    match /c_fs_capacitaciones/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow write: if canWrite() && isSameBarrio(request.resource.data.barrioOrg);
    }

    match /c_fs_pendientes/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow write: if canWrite() && isSameBarrio(request.resource.data.barrioOrg);
    }

    match /c_fs_anotaciones/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if isCreatingOwnAnnotation()
        && canWrite()
        && isSameBarrio(request.resource.data.barrioOrg);
      allow update: if (isSecretary() || isAnnotationOwner())
        && canWrite()
        && request.resource.data.userId == resource.data.userId
        && isSameBarrio(resource.data.barrioOrg);
      allow delete: if (isSecretary() || isAnnotationOwner())
        && canWrite()
        && isSameBarrio(resource.data.barrioOrg);
    }

    match /c_obra_misional_asignaciones/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow write: if canWrite() && isSameBarrio(request.resource.data.barrioOrg);
    }

    match /c_obra_misional_investigadores/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow write: if canWrite() && isSameBarrio(request.resource.data.barrioOrg);
    }

    match /c_obra_misional_amigos_conversos/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow write: if canWrite() && isSameBarrio(request.resource.data.barrioOrg);
    }

    match /c_obra_misional_imagenes/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow write: if canWrite() && isSameBarrio(request.resource.data.barrioOrg);
    }

    match /c_reporte_anual/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow write: if canWrite() && isSameBarrio(request.resource.data.barrioOrg);
    }

    match /c_ministracion_distritos/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow create: if canWrite() && isSameBarrio(request.resource.data.barrioOrg);
      allow update: if canWrite()
        && (isSameBarrio(resource.data.barrioOrg) || isSameBarrio(request.resource.data.barrioOrg));
      // delete no tiene request.resource; validar barrio del documento existente
      allow delete: if canWrite() && isSameBarrio(resource.data.barrioOrg);
    }

    match /c_ministracion_historial/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow write: if canWrite() && isSameBarrio(request.resource.data.barrioOrg);
    }

    match /c_observaciones_salud/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow write: if canWrite() && isSameBarrio(request.resource.data.barrioOrg);
    }

    match /c_notifications/{document} {
      allow read: if isSameBarrio(resource.data.barrioOrg);
      allow write: if canWrite() && isSameBarrio(request.resource.data.barrioOrg);
    }

    // ── User-scoped collections ──

    match /c_push_subscriptions/{document} {
      allow read: if signedIn()
        && resource.data.userId != null
        && resource.data.userId == request.auth.uid;
      allow write: if canWrite()
        && request.resource.data.userId != null
        && request.resource.data.userId == request.auth.uid;
    }

    // ── Audit — already properly restricted ──

    match /c_admin_audit/{document} {
      allow read: if isSecretary();
      allow create: if isSecretary() && request.resource.data.actorUid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Users — existing logic preserved ──

    match /c_users/{document} {
      allow read: if signedIn();
      allow create: if signedIn() && document == request.auth.uid;
      allow update: if signedIn()
        && (
          isSecretary()
          || (
            document == request.auth.uid
            && !request.resource.data.diff(resource.data).changedKeys().hasAny(['role', 'permission'])
          )
        );
      allow delete: if isSecretary();
    }

    // ── Reference data — public read ──

    match /c_barrios/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /c_organizaciones/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Default ──

    match /{document=**} {
      allow read: if signedIn();
    }
  }
}
